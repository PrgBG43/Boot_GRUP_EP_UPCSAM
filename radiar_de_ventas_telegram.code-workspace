      "vue",
      "typescript",
      "typescriptreact",
      "html",
      "json"
    ],
    "eslint.format.enable": true,
    "[jsonc]": {
      "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[json]": {
      "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[javascript]": {
      "editor.tabSize": 2
    },
    "[vue]": {
      "editor.tabSize": 2
    },
